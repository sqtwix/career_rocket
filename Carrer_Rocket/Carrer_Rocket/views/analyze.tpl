% rebase('feedback.tpl', title='Feedback page', year=year)


<div class="page-header text-center">
    <div class="container">
        <h1>📊 Аналитика рынка IT</h1>
        <p>Актуальные данные за {{ year }} год • Более 4000 вакансий</p>
    </div>
</div>

<div class="container">
    <!-- Быстрая статистика -->
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-title">Всего вакансий</div>
            <div class="stat-value">4,532</div>
            <div class="stat-trend">↑ +12% за месяц</div>
        </div>
        <div class="stat-card">
            <div class="stat-title">Средняя ЗП</div>
            <div class="stat-value">218,000 ₽</div>
            <div class="stat-trend">↑ +8% за квартал</div>
        </div>
        <div class="stat-card">
            <div class="stat-title">Всего компаний</div>
            <div class="stat-value">611</div>
            <div class="stat-trend">↑ +23 новых</div>
        </div>
    </div
</div>
